{
    "name": "pitbphp/security-starter",
    "description": "Provides security measures defined by PITB protocols.",
    "keywords": ["pitb", "security", "laravel"],
    "license": "proprietary",
    "type": "composer-plugin",
    "authors": [
        {
            "name": "Talha Saleh Muhammad",
            "email": "talha.saleh@pitb.gov.pk"
        }
    ],
    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.0",
        "ext-json": "*",
        "illuminate/auth": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/notifications": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "mews/captcha": "^3.3",
        "spatie/laravel-permission": "^5.11|^6.0"
    },
    "suggest": {
        "laravel/sanctum": "Required for API mode (SECURITY_MODE=api or hybrid)",
        "spatie/laravel-activitylog": "Lightweight audit logging when auditing.driver is activitylog",
        "owen-it/laravel-auditing": "Full model audit trails when auditing.driver is auditing"
    },
    "autoload": {
        "psr-4": {
            "Pitbphp\\Security\\": "src/"
        }
    },
    "extra": {
        "class": "Pitbphp\\Security\\Composer\\SecurityStarterPlugin",
        "laravel": {
            "providers": [
                "Pitbphp\\Security\\SecurityServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
